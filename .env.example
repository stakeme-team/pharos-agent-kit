# === LLM Provider (for AI SDK examples only) ===
AI_PROVIDER=anthropic                # anthropic | openai
ANTHROPIC_API_KEY=                   # Your Anthropic API key
OPENAI_API_KEY=                      # Your OpenAI API key

# === Wallet (auto-filled by wallet-manager) ===
WALLET_ADDRESS=                      # Public address (safe, used by agent)
PRIVATE_KEY=                         # Private key (NEVER shared with agent)

# === Signer mode ===
SIGNER_MODE=simple                   # simple | secure

# === MCP ===
PHAROS_MCP_URL=https://api.pharos.exploreme.pro/mcp
